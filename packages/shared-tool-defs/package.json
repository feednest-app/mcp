{
  "name": "@feednest/shared-tool-defs",
  "version": "0.1.1",
  "private": true,
  "description": "Shared tool definitions and formatters for FeedNest MCP server and OpenClaw plugin",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@feednest/sdk": "^0.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
