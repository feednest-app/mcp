{
  "name": "@feednest/openclaw",
  "version": "0.1.2",
  "description": "OpenClaw plugin for FeedNest. Your sources inside your AI, on WhatsApp, Telegram, Slack, and every channel you use.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@feednest/sdk": "^0.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/feednest-app/mcp.git",
    "directory": "packages/openclaw-plugin"
  },
  "homepage": "https://www.feednest.com/integrations",
  "keywords": [
    "feednest",
    "openclaw",
    "plugin",
    "news",
    "rss",
    "ai",
    "agent",
    "mcp"
  ]
}
